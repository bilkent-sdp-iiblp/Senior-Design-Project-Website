source "https://rubygems.org"

# Lock to what GitHub Pages supports (pin version for reproducible installs)
gem "github-pages", "232", group: :jekyll_plugins

# Retry middleware for Faraday v2+ (used by jekyll-github-metadata)
gem "faraday-retry"

# Needed for local `bundle exec jekyll serve` on Ruby 3.x
gem "webrick", "~> 1.8"